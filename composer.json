{
    "name": "babelforge/php-rename",
    "type": "library",
    "license": "MIT",
    "description": "PHP refactoring library for safe class and member renaming.",
    "autoload": {
        "psr-4": {
            "BabelForge\\PhpRename\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BabelForge\\PhpRename\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/babelforge/member-graph"
        },
        {
            "type": "vcs",
            "url": "https://github.com/babelforge/php-source-registry"
        }
    ],
    "require": {
        "php": ">=8.4",
        "babelforge/member-graph": "dev-main",
        "nikic/php-parser": "^5.7",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "scripts": {
        "cs": "php-cs-fixer fix --dry-run --diff --sequential",
        "cs-fix": "php-cs-fixer fix --sequential",
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "qa": [
            "@cs",
            "@analyse",
            "@test"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
